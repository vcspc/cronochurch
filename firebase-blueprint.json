{
  "entities": {
    "Schedule": {
      "title": "Schedule",
      "description": "A schedule for a church service.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "items": { "type": "array" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "date", "createdBy"]
    },
    "Template": {
      "title": "Template",
      "description": "A template for a schedule.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "items": { "type": "array" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "createdBy"]
    },
    "History": {
      "title": "History",
      "description": "A history record of an action.",
      "type": "object",
      "properties": {
        "scheduleId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["userId", "action", "timestamp"]
    }
  },
  "firestore": {
    "schedules": { "schema": "Schedule", "description": "Collection of schedules." },
    "templates": { "schema": "Template", "description": "Collection of templates." },
    "history": { "schema": "History", "description": "Collection of history records." }
  }
}
